COOLDOWN_BARS=5

# Sizing
BASE_LOT_EURUSD=0.10
RISK_PER_TRADE_USD=20
MAX_GROSS_NOTIONAL_USD=50000

# Cost model
COMMISSION_USD_PER_MILLION=20.0
